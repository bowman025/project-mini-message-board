<form class="msg-form" method="post" action="/new">
	<div class="msg-form-name">
		<label for="name">Name:</label>
		<input
			required
			type="text"
			name="name"
			id="name"
			placeholder="John Doe"
			maxlength="50"
		>
		<p>*50 characters max</p>
	</div>
	<div class="msg-form-message">
		<label for="message">Message:</label>
		<input
			required
			type="text"
			name="message"
			id="message"
			placeholder="Hello World!"
			maxlength="255"
		>
		<p>*255 characters max</p>
	</div>
	<button class="msg-form-submit">
		<img src="/images/submit.svg" alt="Submit">
	</button>
</form>